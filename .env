# .env
# ─────────────────────────────────────────────────────────────────────────────
# StockFlow — Environment Variables
#
# Expo exposes any variable prefixed with EXPO_PUBLIC_ to the app bundle.
# These are READ-ONLY at runtime (baked in at build time).
#
# Usage in code:
#   import Constants from 'expo-constants';
#   const url = Constants.expoConfig?.extra?.apiUrl;
# ─────────────────────────────────────────────────────────────────────────────

# Default API base URL loaded on first boot.
# The user can override this from the app UI; the override is saved in
# secure storage and takes priority over this value.
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000/api/v1

# App name shown on the configure screen
EXPO_PUBLIC_APP_NAME=StockFlow